{
  "name": "starfolio",
  "type": "module",
  "description": "Starfolio - Create a personal or professional portfolio site just from a single config file. Built with Astro.",
  "author": "websiterating",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "packageManager": "pnpm@10.11.1",
  "pnpm": {
    "overrides": {
      "vite": "^7.3.5",
      "ws": "^8.21.0",
      "devalue": "^5.8.1",
      "fast-uri": "^3.1.2",
      "js-yaml": "^4.1.2",
      "yaml": "^2.8.3",
      "esbuild": "^0.28.1",
      "@babel/core": "^7.29.1"
    },
    "peerDependencyRules": {
      "allowedVersions": {
        "tsconfck>typescript": "6"
      }
    },
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp",
      "workerd"
    ]
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "generate-types": "wrangler types",
    "download-logos": "node scripts/download-logos.mjs"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^13.7.0",
    "@astrojs/mdx": "^5.0.4",
    "@astrojs/react": "^5.0.7",
    "@astrojs/sitemap": "^3.7.2",
    "@fontsource-variable/geist-mono": "^5.2.7",
    "@fontsource-variable/outfit": "^5.2.8",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-icons": "^1.3.2",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.2.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "astro": "^6.4.7",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.14.0",
    "motion": "^12.38.0",
    "next-themes": "^0.4.6",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-markdown": "^10.1.0",
    "rehype-pretty-code": "^0.14.3",
    "remark-gfm": "^4.0.1",
    "shiki": "^4.0.2",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.4",
    "tw-animate-css": "^1.4.0",
    "wrangler": "^4.101.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "typescript": "^6.0.3"
  }
}